# Application
APP_ENV=development
SERVICE_NAME=STAIL Property Discovery Agent
SERVICE_VERSION=1.0.0
PORT=8001
LOG_LEVEL=INFO

# Backend API (where properties/leads live)
BACKEND_API_URL=http://localhost:8000
BACKEND_AGENT_SECRET=

# AI (Groq) — same key as backend, or a separate one
GROQ_API_KEY=your_groq_api_key_here

# CORS — allow only the backend by default
ALLOWED_ORIGINS=["http://localhost:8000"]
