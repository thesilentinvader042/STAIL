# Application
APP_ENV=development
APP_NAME=STAIL Realty OS
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (PostgreSQL)
# Points to Docker db container (start with: docker compose up -d db)
DATABASE_URL=postgresql://realty_user:realty_pass@localhost:5432/realty_os?options=-csearch_path%3Drealty_os%2Cpublic
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# JWT Auth
# In production, replace this with a secure random string (e.g., openssl rand -hex 32)
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (Groq)
# Provide your actual Groq API key here for the AI Agents to work
GROQ_API_KEY=your_groq_api_key_here

# Agent microservice URLs (override for staging/production)
PROPERTY_DISCOVERY_AGENT_URL=http://localhost:8001
LEAD_QUALIFICATION_AGENT_URL=http://localhost:8002
BUYER_AGENT_URL=http://localhost:8003
PROPERTY_AGENT_URL=http://localhost:8004
RECOMMENDATION_AGENT_URL=http://localhost:8005
CRM_AGENT_URL=http://localhost:8006

# AWS (for media storage)
AWS_REGION=ap-south-1
S3_BUCKET_NAME=realty-os-media
