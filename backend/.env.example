# Application
APP_ENV=development
APP_NAME=STAIL Realty OS
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (PostgreSQL)
# If using docker-compose: postgresql://realty_user:realty_pass@localhost:5432/realty_os
# If using local Postgres: postgresql://your_user:your_pass@localhost:5432/realty_os
DATABASE_URL=postgresql://realty_user:realty_pass@localhost:5432/realty_os
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (optional — for future caching)
REDIS_URL=redis://localhost:6379/0

# JWT Auth
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (Groq) — get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Agent Microservices ───────────────────────────────────────────────────────
PROPERTY_DISCOVERY_AGENT_URL=http://localhost:8001
LEAD_QUALIFICATION_AGENT_URL=http://localhost:8002

# AWS (for media storage — optional for local dev)
AWS_REGION=ap-south-1
S3_BUCKET_NAME=realty-os-media
