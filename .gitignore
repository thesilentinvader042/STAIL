# ── Virtual Environments ──────────────────────────────────────────────────────
# venv/ is the canonical virtual environment for this repo.
# .venv/ is ignored so any accidental creation of it is not tracked.
.venv/
.venv
venv/
env/
.env.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so
*.dylib

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Alembic ───────────────────────────────────────────────────────────────────
# Do NOT ignore alembic/versions — migration files must be tracked.
*.pyc

# ── Secrets & Credentials ─────────────────────────────────────────────────────
# .env files contain secrets — ignore all REAL env files.
# .env.example files must be TRACKED so teammates know what vars to set.
.env
backend/.env

# Agent env files (real secrets only, not examples)
agents/buyer-agent/.env
agents/lead-qualification-agent/.env
agents/property-agent/.env
agents/recommendation-agent/.env
agents/crm-agent/.env
agents/property-discovery/.env
agents/orchestrator/.env

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore

# Credentials and secrets files
credentials.json
secrets.yaml
secrets.yml
*-credentials.json
service-account*.json

# ── Docker ────────────────────────────────────────────────────────────────────
# Ignore local volume data if ever mounted to repo dir
postgres_data/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Kiro AI artifacts ─────────────────────────────────────────────────────────
.kiro/

# ── Additional virtual environments ───────────────────────────────────────────
venv_backend/

# ── Error logs & debugging ────────────────────────────────────────────────────
error_logging/

# ── Memory system artifacts ───────────────────────────────────────────────────
memory_system/

# ── Task tracking & planning ──────────────────────────────────────────────────
implementation_plan_*.md
tasks.md
tasks_w2.md

# ── Test & utility scripts ────────────────────────────────────────────────────
check_agents.sh
check_agents1.sh
test_api.py

# ─────────────────────────────────────────────────────────────────────────────
# ── FRONTEND (React + Vite + TypeScript) ─────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────

# Node dependencies — never commit node_modules
node_modules/
**/node_modules/

# Vite build output
frontend/dist/
frontend/.vite/

# Next.js build output (if used later)
frontend/.next/
frontend/out/

# React / TypeScript build artifacts
frontend/build/
frontend/tsconfig.tsbuildinfo
**/*.tsbuildinfo

# Frontend environment files (real secrets only, not examples)
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Package manager lock files — pick ONE and track it, ignore others
# If using npm: track package-lock.json, ignore yarn.lock / pnpm-lock.yaml
yarn.lock
pnpm-lock.yaml
# If using yarn: uncomment the line below and comment out yarn.lock above
# package-lock.json

# Frontend testing
frontend/coverage/
frontend/.nyc_output/

# Storybook (if added later)
frontend/storybook-static/

# PWA / service worker generated files
frontend/sw.js
frontend/workbox-*.js

# ESLint cache
.eslintcache
frontend/.eslintcache

# Prettier cache
.prettier_cache

# Tailwind CSS generated (if using JIT purge outputs)
# frontend/src/styles/tailwind.output.css
